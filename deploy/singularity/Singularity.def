Bootstrap: docker
From: python:3.13-slim

%labels
    Maintainer Félix Nieto-del-Amor <fenda@kth.se>
    Description "NeuroCBIR (CPU) + Snakemake container"
    Version "1.0"

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_NO_CACHE_DIR=1
    export APP_HOME=/app
    export PYTHONPATH=/app
    export PATH="$APP_HOME:$PATH"

%files
    deploy/neurocbir /app/neurocbir
    deploy/configs /app/configs
    deploy/data /app/data
    deploy/snakemake /app/snakemake

%post
    echo "=== 🧠 Building NeuroCBIR Singularity Image ==="
    apt-get update && apt-get install -y --no-install-recommends \
        git wget curl ca-certificates build-essential \
        libglib2.0-0 libsm6 libxext6 libxrender-dev libffi-dev \
        graphviz \
        && rm -rf /var/lib/apt/lists/*

    echo "=== 📦 Installing Python dependencies ==="
    mkdir -p /app
    cd /app

    # Copy requirements
    pip install --no-cache-dir -r /app/neurocbir/requirements.txt

    # Install Snakemake
    pip install --no-cache-dir snakemake==9.12.0

    echo "✅ Setup complete!"

%help
    NeuroCBIR Singularity container (with Snakemake)

    Examples:
      apptainer run neurocbir.sif --help
      apptainer run neurocbir.sif snakemake --use-singularity --profile profile
      apptainer shell neurocbir.sif
